module mac_row (clk, out_s, in_w, in_n, valid, inst_w, two_bit_mode, load_b2, mode_sel, os_out, reset);

  parameter bw = 4;
  parameter psum_bw = 16;
  parameter col = 8;

  input  clk, reset;
  output [psum_bw*col-1:0] out_s;
  output [col-1:0] valid;
  input  [bw-1:0] in_w; // inst[1]:execute, inst[0]: kernel loading
  input  [1:0] inst_w;
  input  [psum_bw*col-1:0] in_n;

  // SIMD signals
  input  two_bit_mode; 
  input  load_b2;

  // Output stationary signals
  input mode_sel; // signal to for output stationary
  input os_out; // signal to for output stationary (details in mac_tile)
  reg os_out_q; // a reg to delay the signal to the array so ofifo can turn on

  // temp is a wide wire vector used to connect the east-west data signals
  wire  [(col+1)*bw-1:0] temp;
  wire  [(col+1)*2-1:0] temp_inst;
  reg [col-1:0] valid_q;

  assign temp[bw-1:0]   = in_w; // first 4 bits for the very start of the row
  assign temp_inst[1:0] = inst_w; // first 2 bits of temp_inst is for very first PE in row
  assign valid = valid_q;

  integer j;
  // logic to set the valid bits
  always @(posedge clk) begin
    if (reset) begin
      valid_q <= 0;
      os_out_q <= 0;
    end
    else if (mode_sel)begin 
      // set all valid bits high once output stationary finishes calculation
      if(os_out)begin
        valid_q <= 8'b11111111; // all ones
        os_out_q <= os_out;
      end
      else begin
        valid_q <= 0;
      end
    end
    else begin 
      for (j = 1; j < col+1; j = j + 1) begin
          valid_q[j-1] <= temp_inst[2*(j)-1];
      end
    end
    
  end

  genvar i;
  for (i=1; i < col+1 ; i=i+1) begin : col_num
      mac_tile #(.bw(bw), .psum_bw(psum_bw)) mac_tile_instance (
        .clk(clk),
        .reset(reset),
        .mode_sel(mode_sel),
        .os_out(os_out_q),
        .two_bit_mode(two_bit_mode),
        .load_b2(load_b2),
        .in_n(in_n[psum_bw*i-1:psum_bw*(i-1)]), // the right bits for the in north input
        .in_w(temp[bw*i-1:bw*(i-1)]),
        .inst_w(temp_inst[2*i-1:2*(i-1)]), // index of input wire from west (for first mac, 2*1 -1 = 1: 2*(1-1) = 0, so 1:0, which is right, as we passed inst_w to these two wires above)
            .out_e(temp[bw*(i+1)-1:bw*i]),
            .inst_e(temp_inst[2*(i+1)-1:2*i]), // index of output wire to the east
            .out_s(out_s[psum_bw*i-1:psum_bw*(i-1)]) // the right bits for the out south output
        ); 
  end



endmodule
